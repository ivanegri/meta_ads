# Token secreto para verificar o webhook da Meta (você define este valor)
META_VERIFY_TOKEN=seu_token_secreto_aqui

# Token de acesso da Meta Graph API para buscar detalhes completos do lead
# Gere em: https://developers.facebook.com/ > Seu App > Ferramentas > Explorador da API Graph
META_ACCESS_TOKEN=seu_access_token_da_meta_aqui

# Segredo do App Meta (usado para validar assinatura do webhook)
META_APP_SECRET=seu_app_secret_aqui

# ID do App Meta — obrigatório para o fluxo de OAuth (Onboarding de Clientes)
# Encontre em: https://developers.facebook.com/ > Seu App > Configurações > Básico
META_APP_ID=seu_app_id_aqui

# URL do banco de dados SQLite (caminho local)
DATABASE_URL=sqlite:///./meta_leads.db
